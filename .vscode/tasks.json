{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Eight Queens GUI",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}/Data_Structure/eight.c",
                "-o",
                "${workspaceFolder}/Data_Structure/output/eight.exe",
                "-Wall",
                "-Wextra",
                "-mwindows"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}